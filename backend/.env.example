# TripIQ Backend Environment Variables
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
# Get it free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Supabase credentials (for saved trips + auth)
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Frontend URL for CORS (update when deploying)
FRONTEND_URL=http://localhost:3000
