# ═══════════════════════════════════════════════════════
#  TripWise Backend — Environment Variables
#  Copy this file to .env for local dev
# ═══════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────
# Google Gemini API key — free at aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── REQUIRED for trip history ───────────────────────────
# Supabase project URL and anon key
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ── REQUIRED on Render ──────────────────────────────────
# Your own Render backend URL — used by the keep-alive bot
RENDER_URL=https://your-service-name.onrender.com

# Frontend URL — used for CORS
FRONTEND_URL=https://tripwiseai.vercel.app
