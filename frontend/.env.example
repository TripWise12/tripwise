# ═══════════════════════════════════════════════════════
#  TripWise Frontend — Environment Variables
#  Copy this file to .env.local for local dev
# ═══════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────
# Your Render backend URL
NEXT_PUBLIC_API_URL=https://your-service-name.onrender.com

# ── REQUIRED — Firebase Google Auth ─────────────────────
# Get all 6 values from:
# console.firebase.google.com → your project
# → Project Settings → General → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-your-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
